{
  "app_type": "general",
  "app_name": "Account WebSocket Events",
  "contact_name": "Example Developer",
  "contact_email": "developer@example.com",
  "company_name": "Example Company",
  "manifest": {
    "display_information": {
      "display_name": "Account WebSocket Events",
      "description": "Receives account meeting events over a WebSocket connection."
    },
    "oauth_information": {
      "usage": "ADMIN_MANAGEMENT",
      "development_redirect_uri": "https://socket.example.com/oauth/callback",
      "production_redirect_uri": "https://socket.example.com/oauth/callback",
      "oauth_allow_list": [
        "https://socket.example.com/oauth/callback"
      ],
      "strict_mode": true,
      "subdomain_strict_mode": true,
      "scopes": [
        {
          "scope": "meeting:read:meeting:admin",
          "optional": false
        }
      ],
      "scope_description": "Read meetings associated with account-level WebSocket events.",
      "enable_private_pkce_client": false,
      "enable_public_pkce_client": false
    },
    "features": {
      "products": [
        "ZOOM_MEETING"
      ],
      "development_home_uri": "https://socket.example.com/",
      "production_home_uri": "https://socket.example.com/",
      "domain_allow_list": [
        {
          "domain": "socket.example.com",
          "explanation": "Hosts the account event consumer."
        }
      ],
      "event_subscription": {
        "enable": false
      }
    }
  }
}
