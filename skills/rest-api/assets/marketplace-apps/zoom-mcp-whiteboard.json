{
  "app_type": "general",
  "app_name": "Whiteboard MCP Connector",
  "contact_name": "Example Developer",
  "contact_email": "developer@example.com",
  "company_name": "Example Company",
  "manifest": {
    "display_information": {
      "display_name": "Whiteboard MCP Connector",
      "description": "Authorizes an MCP client to list, read, create, and update Zoom Whiteboards."
    },
    "oauth_information": {
      "usage": "USER_OPERATION",
      "development_redirect_uri": "https://mcp-client.example.com/oauth/callback",
      "production_redirect_uri": "https://mcp-client.example.com/oauth/callback",
      "oauth_allow_list": [
        "https://mcp-client.example.com/oauth/callback"
      ],
      "strict_mode": true,
      "subdomain_strict_mode": true,
      "scopes": [
        {
          "scope": "whiteboard:read:list_whiteboards",
          "optional": false
        },
        {
          "scope": "whiteboard:read:whiteboard",
          "optional": false
        },
        {
          "scope": "whiteboard:write:whiteboard",
          "optional": false
        },
        {
          "scope": "whiteboard:write:collaborator",
          "optional": false
        },
        {
          "scope": "whiteboard:delete:collaborator",
          "optional": false
        },
        {
          "scope": "whiteboard:update:collaborator",
          "optional": false
        },
        {
          "scope": "whiteboard:read:list_collaborators",
          "optional": false
        }
      ],
      "scope_description": "Use the current Whiteboard MCP read and write tools for the authorizing user.",
      "enable_private_pkce_client": true,
      "enable_public_pkce_client": false
    },
    "features": {
      "products": []
    }
  }
}
